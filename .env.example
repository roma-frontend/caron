# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# App
NEXT_PUBLIC_APP_URL=https://caron.am

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars
AUTH_ISSUER_URL=https://caron.am

# Cloudflare R2 (image uploads)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket-name
# Public base URL of the bucket (used to build image URLs), e.g. https://pub-xxxx.r2.dev
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Admin credentials — set these in the Convex dashboard (used by convex/auth.ts)
ADMIN_EMAIL=admin@caron.am
ADMIN_PASSWORD=change-me-strong-password

# Rate limiting (optional - Upstash Redis). If unset, rate limiting is disabled.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# SEO (optional)
GOOGLE_SITE_VERIFICATION=your-google-site-verification-token

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Email (optional - Resend)
RESEND_API_KEY=your-resend-api-key

# Google Maps (optional)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key

# Error monitoring (optional - Sentry). If unset, monitoring is fully disabled
# (no-op) and has zero runtime/build impact.
# SENTRY_DSN is used server-side; NEXT_PUBLIC_SENTRY_DSN enables the browser SDK.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Hero poster (recommended for LCP): a lightweight image painted instantly
# behind the hero video so LCP no longer waits on the ~1.7MB video.
# Generate: ffmpeg -i hero.mp4 -vframes 1 -q:v 4 -vf scale=1280:-2 hero-poster.jpg
# Upload to R2, then set the key/url here:
# NEXT_PUBLIC_HERO_POSTER_URL=products/hero-poster.jpg

# Web Push notifications (optional). If unset, push is fully disabled (no-op).
# Generate keys: npx web-push generate-vapid-keys --json
# - VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY / VAPID_SUBJECT must be set in the
#   Convex deployment:  npx convex env set VAPID_PUBLIC_KEY <key>  (and private/subject)
# - NEXT_PUBLIC_VAPID_PUBLIC_KEY must equal VAPID_PUBLIC_KEY (used by the browser)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@gmail.com
